from datetime import datetime, timedeltafrom se.airflow import DAGfrom se.airflow.utils.dates import days_agofrom se.airflow.operators.empty import EmptyOperatorfrom se.airflow.providers.spark import SparkSqlOperatorSE, SparkSubmitOperatorSEargs = {    "owner": "{{owner}}" # обязательно явно, ipa_username}hdfs_app_path = "{{hdfs_app_path}}"hdfs_person_path = "{{hdfs_person_path}}"with DAG(    dag_id="{{dag_id}}", # обязательный, под этим названием будет отображаться даг в airflow ui    default_args=args, # словарь параметров,которые применяются для каждого оператора в даге    start_date={{start_date_dag}}, # обязательный, дата старта при запуске дага, поддерживает datetime    schedule_interval={% if "*" in schedule_interval %}"{{schedule_interval}}"{% else %}{{schedule_interval}}{% endif %}, # рассписание автозапуска дага, указывать в формате cron-выражения    dagrun_timeout={{dagrun_timeout}}, # timeout dag run    tags={{tags}}, # ставим команду, login_omega и любые другие    max_active_runs={{max_active_runs}}, # максимальное число активных dag run    catchup={{catchup}}, # при старте дага, запускать ли предыдущие НЕуспешные dag runs, начиная от start_date (включительно) до даты запуска дага (невключительно)    ) as dag:    spark_job = SparkSubmitOperatorSE(        task_id="{{task_id}}",        application=f"{hdfs_app_path}/main.py", # запускается на драйвере spark приложения        application_args=[            "--job_name", "{{job_name}}", # имя джобы в папке src/job_test            # 0 - full, 1 - increment с save_interval, 2 - от start_date до end_date, 3 - от start_date до end_date (без предварительного удаления партиций)            {% if increment == '0' %}"--increment", "{{increment}}",            {% elif increment == '1' %}"--increment", "{{increment}}",            "--save_interval", "{{save_interval}}",            {% elif increment in ['2','3'] %}"--increment", "{{increment}}",            "--start_date", "{{start_date}}",            "--end_date", "{{end_date}}",            {% endif %}            "--schema_ch", "{{schema_ch}}", # схема таблиц в кликхаусе            "--distributed_table", "{{distributed_table}}", # имя шардированной таблицы            "--replicated_table", "{{replicated_table}}", # имя таблицы, над которой построена шардированная            "--schema_hive", "{{schema_hive}}", # схема таблицы в хайве, из которой грузим            "--hive_table", "{{hive_table}}", # имя таблицы в хайве, из которой грузим            "--sharding_key_ch", "{{sharding_key_ch}}", # ключ шардированая в кликхаусе, для удаления по партициям (только одно поле, тип=date)            "--cluster", "{{cluster}}" # имя кластера в кликхаусе        ], # аргументы application        py_files=f"{hdfs_person_path}/.auth/creds.py,{hdfs_person_path}/.auth/{args['owner']}.keytab,{hdfs_app_path}/src.zip,{hdfs_app_path}/jobs.zip", # здесь указываем все необходимые файлы (.creds.py и keytab) и zip архив приложения и zip архив с jobs        jars=f"{hdfs_app_path}/clickhouse-jdbc-0.3.2-patch11-all.jar", # jar файлы кладем сюда, и указываем их в conf, параметр jars        conf={"spark.master": 'yarn', # обязательный              "spark.submit.deployMode": 'cluster', # обязательный              "spark.yarn.queue": '{{spark_yarn_queue}}', # обязательный              "spark.hadoop.hive.metastore.uris": '''thrift://pvlos-sfd000214.cloud.df.sbrf.ru:48101,thrift://pvlos-sfd000238.cloud.df.sbrf.ru:48101''', # обязательный, это адрес MetaStore Hive, без этого параметра не будет видеть MetaStore Hive              "spark.pyspark.python": '{{python_exe_path}}', # обязательный, путь к интерпретатору питона для executor, иначе будут ошибки с импортами сторонних библиотек              "spark.pyspark.driver.python": '{{python_exe_path}}', # обязательный, путь к интерпретатору питона для driver, иначе будут ошибки с импортами сторонних библиотек              "spark.driver.cores": {{spark_driver_cores}}, # кол-во ядер driver, не менять              "spark.driver.memory": "{{spark_driver_memory}}", # оператива driver, не менять              "spark.executor.cores": {{spark_executor_cores}}, # кол-во ядер на executor, делаешь больше, если нужна выше скорость (вместе с ним менять и параметры spark.default.parallelism и spark.sql.shuffle.partitions)              "spark.executor.memory": "{{spark_executor_memory}}", # оператива на executor              "spark.executor.instances": {{spark_instances}}, # кол-во executor (executor.cores*executor.instances должно быть меньше 40, для дага на постоянной основе, чтобы не мешать другим коллегам, грузить данные, тк общее кол-во ядер на очереди team_rdwh_reserv =1200)              "spark.executor.memoryOverhead": "{{spark_executor_memory_overhead}}", # 20% от executor.memory              "spark.driver.memoryOverhead": "{{spark_driver_memory_overhead}}", # 20% от driver.memory              "spark.sql.parquet.binaryAsString": "true", # читать тип binary как string              "spark.sql.hive.convertMetastoreParquet": "false", # для совместимости типов данных spark и старых версий hive (иначе timestamp поменяет формат)              "spark.shuffle.service.enabled": "true", # всегда должен true, для шафл операций между executors              "spark.sql.parquet.readLegacyFormat": "true", # для совместимости с legacy версиями parquet              "spark.hadoop.validateOutputSpecs": "false", # чтобы не было ошибок, если перезаписываешь какие то данные              "spark.hadoop.mapred.input.dir.recursive": "true", # для чтения партицированных таблиц всегда делаем true              "spark.sql.catalogImplementation": "hive", # указывать, если работаешь с hive              "spark.hadoop.metastore.skip.load.functions.on.init": "true", # true, если НЕ используешь udf из hive (то есть всегда true)              "jars": "clickhouse-jdbc-0.3.2-patch11-all.jar", # jar для работы с clickhouse              "spark.hadoop.hive.metastore.uris": 'thrift://pvlos-sfd000214.cloud.df.sbrf.ru:48101,thrift://pvlos-sfd000238.cloud.df.sbrf.ru:48101', # ДЛЯ ЧТЕНИЯ ИЗ ПОДПИСКИ: обязательный, это адрес MetaStore Hive, без этого параметра не будет видеть MetaStore Hive              "spark.yarn.access.hadoopFileSystems": 'hdfs://hdfsgw', # ДЛЯ ЧТЕНИЯ ИЗ ПОДПИСКИ: без этого параметра будет ошибка кербероса              "spark.hadoop.yarn.timeline-service.enabled": "false"             },        verbose=True # True - вывод подробных логов    )    start = EmptyOperator(task_id="start")    finish = EmptyOperator(task_id="finish")    start >> [spark_job, ] >> finish
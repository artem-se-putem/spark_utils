create or replace table rrb_ext.{{replicated_table}} on cluster '{{cluster}}'    (    {{columns_types}},    `tech_create_dttm` DateTime64(6) default now64()    )    ENGINE = MergeTree()        ORDER BY tuple() -- укажите поля order_by после автогенерации ddl        {% if sharding_key_ch %}PARTITION BY {{sharding_key_ch}}{% endif %};create or replace table rrb_ext.{{distributed_table}} ON CLUSTER '{{cluster}}' as rrb_ext.{{replicated_table}}    ENGINE = Distributed('{{cluster}}', 'rrb_ext', '{{replicated_table}}',  rand());-- Рекомендации по ORDER BY:-- Поля указанные в ORDER BY не должны содержать null в источнике!!! Иначе загрузка упадёт.-- Сначала - указывать поля, по которым чаще всего будете фильтроваться.-- Далее первыми должны идти поля по возрастанию кардинальности.-- Если таблица небольшая можно указать: ORDER BY tuple()-- Рекомендации по PARTITION BY:-- В приложении удаление партиций при инкрементальной загрузке работает только, если партицированное поле имеет формат даты YYYY-MM-DD (тип может быть String или Date).-- Поэтому, если поле не сооветствует этим требованиям, нужно будет заранее вручную почистить эти партиции перед загрузкой.-- Историческая загрузка работает все зависимости от поля партицирования.-- CLUSTER и схему таблицы можно указывать любые-- ENGINE можно поменять на ReplicatedMergeTree